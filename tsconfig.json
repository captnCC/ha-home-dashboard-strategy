{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "paths": {
      "@ha/*": ["homeassistant/src/*"]
    }
  },
  "include": ["src"]
}
